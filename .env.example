# Backend environment variables for fearfree-backend

# Either DATABASE_URL or the individual DB_* values are used.
# Example: postgres://user:password@host:5432/dbname?sslmode=disable
DATABASE_URL=

DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fearfree
DB_PORT=5432

JWT_SECRET=your-secure-jwt-secret-here
CORS_ORIGIN=http://localhost:3000
PORT=8080
